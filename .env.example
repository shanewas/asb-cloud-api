# Application
ASB_CONFIG_PATH=config.yaml

# Screenshot output directory (feeds screenshots.dir in config.yaml).
# v1 uses local FS paths only. Self-hosted users access files via bind mounts/volumes.
# For hosted cloud/SaaS deployments, set screenshots.enabled=false in config.yaml
# so that screenshot_url remains null and no internal paths are ever returned.
ASB_SCREENSHOT_DIR=/tmp/screenshots

# Optional PostgreSQL persistence. Leave empty for in-memory local dev mode.
DATABASE_URL=

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
COOKIE_ENCRYPTION_KEY=

# Stripe billing. Required only if billing routes are enabled for deployment.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_LICENSE_SOLO=
STRIPE_LICENSE_TEAM=
STRIPE_LICENSE_ENTERPRISE=

# Self-hosted license verification.
LICENSE_SECRET_KEY=

