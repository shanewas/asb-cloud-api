# Application
ASB_CONFIG_PATH=config.yaml
ASB_SCREENSHOT_DIR=/tmp/screenshots

# Optional PostgreSQL persistence. Leave empty for in-memory local dev mode.
DATABASE_URL=

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
COOKIE_ENCRYPTION_KEY=

# Stripe billing. Required only if billing routes are enabled for deployment.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_LICENSE_SOLO=
STRIPE_LICENSE_TEAM=
STRIPE_LICENSE_ENTERPRISE=

# Self-hosted license verification.
LICENSE_SECRET_KEY=

# =============================================================================
# Docker Compose PostgreSQL Smoke Stack (see docker-compose.yml and README)
# =============================================================================
# These values are used when running the local dev smoke stack with PostgreSQL.
# THEY ARE FOR LOCAL DEVELOPMENT AND SMOKE TESTING ON YOUR MACHINE ONLY.
# Do not use these defaults anywhere that matters.

# When using docker compose, DATABASE_URL is usually set directly in the compose file.
# DATABASE_URL=postgresql://asb:asb_dev_only_change_me@postgres:5432/asb_dev

# A development-only Fernet key (pre-validated). Generate/rotate for any serious use:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   Verify: python -c "from cryptography.fernet import Fernet; Fernet('the-key-here')"
COOKIE_ENCRYPTION_KEY=DenyyNaEkOmFHIuLm3YXfuCA7D7nZNtgKKmYfUsp8eo=

